# ============================================================
# HUGLO LEPAGE AVOCATS — Variables d'environnement requises
# ============================================================
# Copiez ce fichier en ".env.local" et remplissez les valeurs.
# Ne jamais committer le fichier .env.local sur GitHub !

# ── NEXTAUTH ─────────────────────────────────────────────────
# URL publique de l'application (en production : https://votre-app.vercel.app)
NEXTAUTH_URL=http://localhost:3000

# Clé secrète aléatoire (générez-en une avec : openssl rand -base64 32)
AUTH_SECRET=REMPLACER_PAR_UNE_CLE_ALEATOIRE

# ── MICROSOFT AZURE AD ───────────────────────────────────────
# Obtenus depuis portal.azure.com > App registrations
# (Voir les instructions dans README ou demandez à votre administrateur IT)
AZURE_AD_CLIENT_ID=VOTRE_CLIENT_ID
AZURE_AD_CLIENT_SECRET=VOTRE_CLIENT_SECRET
AZURE_AD_TENANT_ID=VOTRE_TENANT_ID

# ── SUPABASE ──────────────────────────────────────────────────
